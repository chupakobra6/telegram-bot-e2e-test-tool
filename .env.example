# Обязательные Telegram credentials из https://my.telegram.org
TG_E2E_APP_ID=12345678
TG_E2E_APP_HASH=your_telegram_app_hash

# Тестовый Telegram-аккаунт, через который tool логинится в MTProto
TG_E2E_PHONE=+79990000000

# Опционально: только если у аккаунта включен Telegram 2FA
TG_E2E_PASSWORD=

# Практически полезно почти всегда
TG_E2E_DEFAULT_CHAT=@your_bot_username

# Окно видимой истории и частота синка
TG_E2E_HISTORY_LIMIT=50
TG_E2E_SYNC_INTERVAL_MS=1200

# Прокси для MTProto
# HTTP_PROXY / HTTPS_PROXY работают через HTTP CONNECT
# ALL_PROXY можно использовать для SOCKS5
HTTP_PROXY=
HTTPS_PROXY=
ALL_PROXY=
NO_PROXY=localhost,127.0.0.1

# Продвинутые overrides путей обычно не нужны.
# По умолчанию tool сам использует:
#   session: .sessions/user.json
#   transcripts: artifacts/transcripts
# TG_E2E_SESSION_PATH=.sessions/user.json
# TG_E2E_TRANSCRIPT_DIR=artifacts/transcripts
