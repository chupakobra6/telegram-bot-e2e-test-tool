# Telegram app credentials
# Replace the example values with your real ones from https://my.telegram.org.
TG_E2E_APP_ID=12345678
TG_E2E_APP_HASH=0123456789abcdef0123456789abcdef

# Test account login
TG_E2E_PHONE=+79990000000

# Optional 2FA
TG_E2E_PASSWORD=your_telegram_2fa_password

# Optional MTProto proxy
# HTTP_PROXY / HTTPS_PROXY work through HTTP CONNECT
# ALL_PROXY can be used for SOCKS5
HTTP_PROXY=http://127.0.0.1:8888
HTTPS_PROXY=http://127.0.0.1:8888
ALL_PROXY=socks5://127.0.0.1:1080
NO_PROXY=localhost,127.0.0.1

# Optional path overrides
# Normal setup does not need these because the tool defaults to:
#   session: .sessions/user.json
#   transcripts: artifacts/transcripts
# If you still need an override, the format looks like this:
# TG_E2E_SESSION_PATH=/Users/igor/.telegram-e2e/session.json
# TG_E2E_TRANSCRIPT_DIR=/Users/igor/.telegram-e2e/transcripts

# Optional Shelfy control API override for control-backed suite flows
# The built-in full Shelfy suite defaults to http://127.0.0.1:8081.
# CONTROL_URL=http://127.0.0.1:8081
