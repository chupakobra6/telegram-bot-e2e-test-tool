# Telegram app credentials from https://my.telegram.org
TG_E2E_APP_ID=12345678
TG_E2E_APP_HASH=your_telegram_app_hash

# Test user account used by the tool for MTProto login
TG_E2E_PHONE=+79990000000

# Optional: only if the account has Telegram 2FA enabled
TG_E2E_PASSWORD=

# Optional runtime paths and defaults
TG_E2E_SESSION_PATH=.sessions/user.json
TG_E2E_TRANSCRIPT_DIR=artifacts/transcripts
TG_E2E_DEFAULT_CHAT=@your_bot_username

# Chat sync behavior
TG_E2E_HISTORY_LIMIT=50
TG_E2E_SYNC_INTERVAL_MS=1200

