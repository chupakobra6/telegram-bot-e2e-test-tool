# Covers click_button on dashboard, wait on pinned edit,
# and back navigation through the same pinned message.
# Assumes the suite already established a fresh home dashboard.
{"id":"select_chat","action":"select_chat","chat":"@your_bot_username"}
{"id":"open_stats","action":"click_button","button_text":"📊 Статистика"}
{"id":"wait_stats","action":"wait","timeout_ms":12000}
{"id":"back_home","action":"click_button","button_text":"⬅️ Назад"}
{"id":"wait_home","action":"wait","timeout_ms":12000}
{"id":"dump_navigation","action":"dump_state"}
